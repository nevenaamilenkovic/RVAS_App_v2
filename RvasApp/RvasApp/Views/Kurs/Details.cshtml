@model RvasApp.Models.Kurs

@{
    ViewData["Title"] = "Detalji kursa";
}

@section Styles {
    <link rel="stylesheet" href="~/css/kurs.css" asp-append-version="true" />
}

<div class="course-details-page">
    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <section class="details-main-card">
                <p class="details-label">Detalji kursa</p>
                <h1 class="details-title">@Model.Naziv</h1>
                <p class="details-instructor">
                    Instruktor:
                    <strong>@Model.Instruktor.Ime @Model.Instruktor.Prezime</strong>
                </p>

                <div class="details-divider"></div>

                <h4 class="details-section-title">Opis kursa</h4>
                <p class="details-description">
                    @(string.IsNullOrWhiteSpace(Model.Opis)
                        ? "Nema opisa za ovaj kurs."
                        : Model.Opis)
                </p>
            </section>

            @if (User.IsInRole("Polaznik") && ViewBag.JePrijavljen == true)
            {
                <section class="lessons-card mt-4">
                    <h4 class="details-section-title mb-2">Pristup sadrzaju kursa</h4>
                    <p class="text-muted mb-3">
                        Upisani ste na kurs. Lekcije i materijale mozete pogledati na posebnoj stranici kursaa.
                    </p>
                    <a asp-action="DetaljiUpisanogKursa" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                        Otvori lekcije i materijale
                    </a>
                </section>
            }
        </div>

        <div class="col-12 col-lg-4">
            <aside class="details-side-card">
                <h5 class="side-title">Informacije</h5>

                <div class="info-row">
                    <span class="info-label">Pocetak</span>
                    <span class="info-value">@(Model.DatumPocetka?.ToString("dd.MM.yyyy") ?? "-")</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Zavrsetak</span>
                    <span class="info-value">@(Model.DatumZavrsetka?.ToString("dd.MM.yyyy") ?? "-")</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Max polaznika</span>
                    <span class="info-value">@(Model.MaksimalanBrojPolaznika?.ToString() ?? "-")</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Kontakt</span>
                    <span class="info-value">@Model.Instruktor.Email</span>
                </div>

                <hr />

                @if (User.IsInRole("Polaznik"))
                {
                    @if (ViewBag.JePrijavljen == true)
                    {
                        <form asp-action="IspisiSe" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger w-100 mb-2">
                                Ispisi se sa kursa
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="PrijaviSe" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary w-100 mb-2">
                                Upisi se na kurs
                            </button>
                        </form>
                    }
                }

                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    Nazad na kurseve
                </a>
            </aside>
        </div>
    </div>
</div>