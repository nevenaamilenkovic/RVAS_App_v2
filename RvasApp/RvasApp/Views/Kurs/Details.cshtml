@model RvasApp.Models.Kurs

@{
    ViewData["Title"] = "Detalji kursa";
}

<div class="container mt-4">

    <div class="row">
        <div class="col-md-8">
            <h1 class="mb-3">@Model.Naziv</h1>
            <p class="text-muted">
                Instruktor:
                <strong>@Model.Instruktor.Ime @Model.Instruktor.Prezime</strong>
            </p>

            <hr />
            <h4>Opis kursa</h4>
            <p>
                @(string.IsNullOrWhiteSpace(Model.Opis)
                    ? "Nema opisa za ovaj kurss"
                    : Model.Opis)
            </p>

            @if (User.IsInRole("Polaznik"))
            {
                if (ViewBag.JePrijavljen == true)
                {
                    <hr />
                    <h4>Lekcije</h4>

                    @if (Model.Lekcije != null && Model.Lekcije.Any())
                    {
                        <div class="accordion" id="lekcijeAccordion">
                            @foreach (var lekcija in Model.Lekcije.OrderBy(l => l.Naziv))
                            {
                                var collapseId = $"lekcija-collapse-{lekcija.Id}";
                                var headingId = $"lekcija-heading-{lekcija.Id}";

                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="@headingId">
                                        <button class="accordion-button collapsed" type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#@collapseId"
                                                aria-expanded="false"
                                                aria-controls="@collapseId">
                                            @lekcija.Naziv
                                        </button>
                                    </h2>
                                    <div id="@collapseId" class="accordion-collapse collapse"
                                         aria-labelledby="@headingId"
                                         data-bs-parent="#lekcijeAccordion">
                                        <div class="accordion-body" style="white-space: pre-wrap;">
                                            @lekcija.Sadrzaj

                                            @if (lekcija.Materijali != null && lekcija.Materijali.Any())
                                            {
                                                <hr />
                                                <h6 class="mb-2">Materijali</h6>
                                                <div class="list-group">
                                                    @foreach (var m in lekcija.Materijali.OrderBy(x => x.DatumOtpremanja))
                                                    {
                                                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                                           asp-controller="Lekcija"
                                                           asp-action="PreuzmiMaterijal"
                                                           asp-route-id="@m.Id">
                                                            <div class="me-3">
                                                                <div class="fw-semibold">@m.Naziv</div>
                                                                <small class="text-muted">@m.DatumOtpremanja.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                                                            </div>
                                                            <span class="badge bg-light text-dark border">@Math.Round(m.Velicina / 1024d, 0) KB</span>
                                                        </a>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Trenutno nema lekcija za ovaj kurs.</p>
                    }
                }
            }

        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Informacije</h5>

                        <strong>Pocetak:</strong><br />
                        @(Model.DatumPocetka?.ToString("dd.MM.yyyy") ?? "-")
                    </p>

                    <p>
                        <strong>Zavrsetak:</strong><br />
                        @(Model.DatumZavrsetka?.ToString("dd.MM.yyyy") ?? "-")
                    </p>

                    <p>
                        <strong>Max polaznika:</strong><br />
                        @(Model.MaksimalanBrojPolaznika?.ToString() ?? "-")
                    </p>

                    <p>
                        <strong>Kontakt:</strong><br />
                        @Model.Instruktor.Email
                    </p>

                    <hr />
                    @if (User.IsInRole("Polaznik"))
                    {
                        @if (ViewBag.JePrijavljen==true)
                        {                        
                            @* ako je prijavljen moze da se ispise sa kursa *@
                            <form asp-action="IspisiSe" method="post">
                                <input type="hidden" name="id" value="@Model.Id"/>
                                <button type="submit" class="btn btn-danger w-100 mb-2">
                                    Ispisi se sa kursa
                                </button>
                            </form>
                        }
                        else
                        {
                            @* polaznici ce moci da se prijavljuju na kurs sa details stranice *@
                            <form asp-action="PrijaviSe" method="post">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-primary w-100 mb-2">
                                    Upisi se na kurs
                                </button>
                            </form>
                        }
                    }

                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        Nazad
                    </a>

                </div>
            </div>

        </div>
    </div>

</div>