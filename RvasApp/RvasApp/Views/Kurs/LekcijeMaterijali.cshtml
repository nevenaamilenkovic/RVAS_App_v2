@model RvasApp.Models.Kurs

@{
    ViewData["Title"] = "Lekcije i materijali";
}

<div class="container mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
        <div>
            <h2 class="mb-1">Lekcije i materijali</h2>
            <div class="text-muted">@Model.Naziv</div>
        </div>
        <a asp-action="MojiKursevi" class="btn btn-outline-secondary">Nazad</a>
    </div>

    @if (Model.Lekcije != null && Model.Lekcije.Any())
    {
        <div class="accordion" id="instruktorLekcijeAccordion">
            @foreach (var lekcija in Model.Lekcije.OrderBy(l => l.Naziv))
            {
                var collapseId = $"instruktor-lekcija-collapse-{lekcija.Id}";
                var headingId = $"instruktor-lekcija-heading-{lekcija.Id}";

                <div class="accordion-item">
                    <h2 class="accordion-header" id="@headingId">
                        <button class="accordion-button collapsed" type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#@collapseId"
                                aria-expanded="false"
                                aria-controls="@collapseId">
                            @lekcija.Naziv
                        </button>
                    </h2>
                    <div id="@collapseId" class="accordion-collapse collapse"
                         aria-labelledby="@headingId"
                         data-bs-parent="#instruktorLekcijeAccordion">
                        <div class="accordion-body">
                            <div class="row g-3">
                                <div class="col-lg-7">
                                    <div class="card border-0 shadow-sm">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <h5 class="mb-0">Materijali</h5>
                                                <span class="badge bg-secondary">Lekcija #@lekcija.Id</span>
                                            </div>

                                            @if (lekcija.Materijali != null && lekcija.Materijali.Any())
                                            {
                                                <div class="list-group">
                                                    @foreach (var m in lekcija.Materijali.OrderByDescending(x => x.DatumOtpremanja))
                                                    {
                                                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                                           href="/@m.Putanja" target="_blank" rel="noopener">
                                                            <div class="me-3">
                                                                <div class="fw-semibold">@m.Naziv</div>
                                                                <small class="text-muted">@m.DatumOtpremanja.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                                                            </div>
                                                            <span class="badge bg-light text-dark border">@Math.Round(m.Velicina / 1024d, 0) KB</span>
                                                        </a>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="text-muted">Nema uploadovanih materijala</div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-5">
                                    <div class="card border-0 shadow-sm">
                                        <div class="card-body">
                                            <h5 class="card-title mb-3">Dodaj materijal</h5>

                                            <form asp-controller="Lekcija"
                                                  asp-action="UploadMaterijal"
                                                  asp-route-id="@lekcija.Id"
                                                  method="post"
                                                  enctype="multipart/form-data">
                                                @Html.AntiForgeryToken()

                                                <div class="mb-3">
                                                    <label class="form-label">Naziv (opciono)</label>
                                                    <input name="naziv" class="form-control" maxlength="200" />
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">Fajl</label>
                                                    <input type="file" name="fajl" class="form-control"
                                                           accept=".pdf,.doc,.docx,.ppt,.pptx,.zip,.rar,.txt" />
                                                    <div class="form-text">Dozvoljeno: pdf, doc/docx, ppt/pptx, zip, rar…</div>
                                                </div>

                                                <button type="submit" class="btn btn-primary w-100">Upload</button>
                                            </form>
                                        </div>
                                    </div>

                                    <div class="card border-0 shadow-sm mt-3">
                                        <div class="card-body">
                                            <h6 class="mb-2">Sadržaj lekcije</h6>
                                            <div class="text-muted" style="white-space: pre-wrap;">@lekcija.Sadrzaj</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">Ovaj kurs trenutno nema lekcija.</div>
    }
</div>

