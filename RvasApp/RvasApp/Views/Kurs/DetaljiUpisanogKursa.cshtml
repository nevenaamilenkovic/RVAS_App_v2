@model RvasApp.Models.Kurs
@{
    ViewData["Title"] = "Sadrzaj kursa";
}

@section Styles {
    <link rel="stylesheet" href="~/css/kurs.css" asp-append-version="true" />
}

<div class="course-details-page">
    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <section class="details-main-card">
                <p class="details-label">Upisani kurs</p>
                <h1 class="details-title">@Model.Naziv</h1>
                <p class="details-instructor">
                    Instruktor:
                    <strong>@Model.Instruktor.Ime @Model.Instruktor.Prezime</strong>
                </p>

                <div class="details-divider"></div>
                <h4 class="details-section-title">Opis kursa</h4>
                <p class="details-description">
                    @(string.IsNullOrWhiteSpace(Model.Opis)
                        ? "Nema opisa za ovaj kurs."
                        : Model.Opis)
                </p>
            </section>

            <section class="lessons-card mt-4">
                <h4 class="details-section-title mb-3">Lekcije</h4>

                @if (Model.Lekcije != null && Model.Lekcije.Any())
                {
                    <div class="accordion lessons-accordion" id="lekcijeAccordion">
                        @foreach (var lekcija in Model.Lekcije.OrderBy(l => l.Naziv))
                        {
                            var collapseId = $"lekcija-collapse-{lekcija.Id}";
                            var headingId = $"lekcija-heading-{lekcija.Id}";

                            <div class="accordion-item">
                                <h2 class="accordion-header" id="@headingId">
                                    <button class="accordion-button collapsed" type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#@collapseId"
                                            aria-expanded="false"
                                            aria-controls="@collapseId">
                                        @lekcija.Naziv
                                    </button>
                                </h2>
                                <div id="@collapseId" class="accordion-collapse collapse"
                                     aria-labelledby="@headingId"
                                     data-bs-parent="#lekcijeAccordion">
                                    <div class="accordion-body lesson-content">
                                        @lekcija.Sadrzaj

                                        @if (lekcija.Materijali != null && lekcija.Materijali.Any())
                                        {
                                            <hr />
                                            <h6 class="mb-2">Materijali</h6>
                                            <div class="list-group material-list">
                                                @foreach (var m in lekcija.Materijali.OrderBy(x => x.DatumOtpremanja))
                                                {
                                                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                                       asp-controller="Lekcija"
                                                       asp-action="PreuzmiMaterijal"
                                                       asp-route-id="@m.Id">
                                                        <div class="me-3">
                                                            <div class="fw-semibold">@m.Naziv</div>
                                                            <small class="text-muted">@m.DatumOtpremanja.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                                                        </div>
                                                        <span class="badge bg-light text-dark border">@Math.Round(m.Velicina / 1024d, 0) KB</span>
                                                    </a>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">Trenutno nema lekcija za ovaj kurs.</p>
                }
            </section>
        </div>

        <div class="col-12 col-lg-4">
            <aside class="details-side-card">
                <h5 class="side-title">Informacije</h5>

                <div class="info-row">
                    <span class="info-label">Pocetak</span>
                    <span class="info-value">@(Model.DatumPocetka?.ToString("dd.MM.yyyy") ?? "-")</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Zavrsetak</span>
                    <span class="info-value">@(Model.DatumZavrsetka?.ToString("dd.MM.yyyy") ?? "-")</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Max polaznika</span>
                    <span class="info-value">@(Model.MaksimalanBrojPolaznika?.ToString() ?? "-")</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Kontakt</span>
                    <span class="info-value">@Model.Instruktor.Email</span>
                </div>

                <hr />
                <a asp-action="MojiUpisaniKursevi" class="btn btn-outline-secondary w-100">
                    Nazad na moje kurseve
                </a>
            </aside>
        </div>
    </div>
</div>
