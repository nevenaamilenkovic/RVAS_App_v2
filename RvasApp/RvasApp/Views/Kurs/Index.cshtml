@model IEnumerable<RvasApp.Models.Kurs>
@{
    ViewData["Title"] = "Svi kursevi";
}

@section Styles {
    <link rel="stylesheet" href="~/css/kurs.css" asp-append-version="true" />
}

<div class="courses-page">
    <div class="courses-header">
        <div>
            <h1 class="courses-title">Dostupni kursevi</h1>
            <p class="courses-subtitle">Pregled aktivnih kurseva i osnovnih informacija.</p>
        </div>

        @if (User.IsInRole("Instruktor"))
        {
            <a asp-action="Create" class="btn btn-primary create-course-btn">Kreiraj kurs</a>
        }
    </div>

    @if (!Model.Any())
    {
        <p class="empty-courses">Trenutno nema dostupnih kurseva.</p>
    }
    else
    {
        <div class="row course-grid">
            @foreach (var kurs in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card course-card h-100">
                        <div class="card-body">
                            <h5 class="course-name">@kurs.Naziv</h5>

                            <p class="course-meta">
                                <strong>Instruktor:</strong><br />
                                @kurs.Instruktor.Ime @kurs.Instruktor.Prezime
                            </p>

                            <p class="course-meta">
                                <strong>Pocetak:</strong> @(kurs.DatumPocetka?.ToString("dd.MM.yyyy") ?? "-")<br />
                                <strong>Zavrsetak:</strong> @(kurs.DatumZavrsetka?.ToString("dd.MM.yyyy") ?? "-")
                            </p>

                            <p class="course-meta mb-0">
                                <strong>Max polaznika:</strong> @(kurs.MaksimalanBrojPolaznika?.ToString() ?? "-")
                            </p>
                        </div>

                        <div class="card-footer bg-transparent border-0">
                            <a asp-action="Details"
                               asp-route-id="@kurs.Id"
                               class="btn btn-outline-primary w-100">
                                Pogledaj detalje
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>