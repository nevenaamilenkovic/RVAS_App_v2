@model RvasApp.Models.Lekcija
@{
    ViewData["Title"] = "Dodaj lekciju";
}

<form asp-action="DodajLekciju" method="post" asp-route-id="@Model.KursId">
    <div class="form-group">
        <label asp-for="Naziv"></label>
        <input asp-for="Naziv" class="form-control" />
        <span asp-validation-for="Naziv"></span>
    </div>

    <div class="form-group">
        <label asp-for="Sadrzaj"></label>
        <textarea asp-for="Sadrzaj" class="form-control"></textarea>
        <span asp-validation-for="Sadrzaj"></span>
    </div>

    <input type="hidden" asp-for="KursId"/>

    <button type="submit" class="btn btn-primary">Sacuvaj</button>
</form>
