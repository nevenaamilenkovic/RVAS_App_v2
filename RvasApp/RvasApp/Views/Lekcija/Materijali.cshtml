@model RvasApp.Models.Lekcija

@{
    ViewData["Title"] = "Materijali lekcije";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8">
            <h2 class="mb-1">Materijali</h2>
            <div class="text-muted mb-3">@Model.Naziv</div>

            @if (Model.Materijali != null && Model.Materijali.Any())
            {
                <div class="list-group">
                    @foreach (var m in Model.Materijali.OrderBy(x => x.DatumOtpremanja))
                    {
                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                           href="/@m.Putanja" target="_blank" rel="noopener">
                            <div class="me-3">
                                <div class="fw-semibold">@m.Naziv</div>
                                <small class="text-muted">@m.DatumOtpremanja.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                            </div>
                            <span class="badge bg-secondary">@Math.Round(m.Velicina / 1024d, 0) KB</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">Jos nema uploadovanih materijala.</p>
            }
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Upload materijala</h5>

                    <form asp-action="UploadMaterijal" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label">Naziv (opciono)</label>
                            <input name="naziv" class="form-control" maxlength="200" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Fajl</label>
                            <input type="file" name="fajl" class="form-control"
                                   accept=".pdf,.doc,.docx,.ppt,.pptx,.zip,.rar,.txt" />
                            <div class="form-text">Dozvoljeno: pdf, doc/docx, ppt/pptx, zip, rar…</div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Otpremi</button>
                    </form>
                </div>
            </div>

            <a asp-controller="Kurs" asp-action="Details" asp-route-id="@Model.KursId" class="btn btn-outline-secondary w-100 mt-3">
                Nazad na kurs
            </a>
        </div>
    </div>
</div>

