@using RvasApp.Models.ViewModels
@model AdminPanelViewModel
@{
    ViewData["Title"] = "Admin panel";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<div class="admin-dashboard">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
        <div>
            <h1 class="dashboard-title">Admin panel</h1>
            <p class="dashboard-subtitle">Upravljanje korisnicima i ulogama na platformi</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="card metric-card total h-100">
                <div class="card-body">
                    <p class="metric-label">Ukupan broj korisnika</p>
                    <p class="metric-value">@Model.BrojKorisnika</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card metric-card instructors h-100">
                <div class="card-body">
                    <p class="metric-label">Instruktori</p>
                    <p class="metric-value">@Model.BrojInstruktora</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card metric-card students h-100">
                <div class="card-body">
                    <p class="metric-label">Polaznici</p>
                    <p class="metric-value">@Model.BrojPolaznika</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card management-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5>Korisnici i uloge</h5>
            <span class="badge text-bg-primary">Ukupno korisnika: @Model.Korisnici.Count()</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover users-table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Ime</th>
                        <th>Prezime</th>
                        <th>Korisnicko ime</th>
                        <th>Uloge</th>
                        <th class="text-center">Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var korisnik in Model.Korisnici)
                    {
                        <tr>
                            <td>@korisnik.Email</td>
                            <td>@korisnik.Ime</td>
                            <td>@korisnik.Prezime</td>
                            <td>@korisnik.KorisnickoIme</td>
                            <td>
                                @if (korisnik.Roles.Any())
                                {
                                    @foreach (var role in korisnik.Roles)
                                    {
                                        var roleClass = role == "Instruktor" ? "instruktor" : role == "Polaznik" ? "polaznik" : "none";
                                        <span class="role-badge @roleClass">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="role-badge none">Nema uloge</span>
                                }
                            </td>
                            <td>
                                <div class="action-group">
                                    @if (!korisnik.Roles.Contains("Instruktor"))
                                    {
                                        <form asp-action="DodeliInstruktorRolu" method="post">
                                            <input type="hidden" name="korisnikId" value="@korisnik.Id" />
                                            <button type="submit" class="btn btn-sm btn-success">Dodeli ulogu instruktora</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="OduzmiInstruktorRolu" method="post">
                                            <input type="hidden" name="korisnikId" value="@korisnik.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning">Oduzmi ulogu</button>
                                        </form>
                                    }

                                    @if (!korisnik.Roles.Any())
                                    {
                                        <form asp-action="DodeliPolaznikRolu" method="post">
                                            <input type="hidden" name="korisnikId" value="@korisnik.Id" />
                                            <button type="submit" class="btn btn-sm btn-primary">Dodeli ulogu polaznik</button>
                                        </form>
                                    }
                                    else if (korisnik.Roles.Contains("Polaznik"))
                                    {
                                        <form asp-action="OduzmiPolaznikRolu" method="post">
                                            <input type="hidden" name="korisnikId" value="@korisnik.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Oduzmi ulogu</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
